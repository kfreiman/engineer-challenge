# Application Configuration
# Schema for URLs: http:// for local, https:// for production
ORBITTO_SCHEMA=http://
# Hostname for the application
ORBITTO_HOSTNAME=orbitto.localhost

# Kratos PostgreSQL Database Configuration
ORBITTO_KRATOS_DB_USER=kratos
ORBITTO_KRATOS_DB_PASSWORD=your_secure_password_here
ORBITTO_KRATOS_DB_NAME=kratos_db

# Kratos Security Secrets
# Cookie secret must be at least 16 bytes (use: openssl rand -hex 16)
ORBITTO_KRATOS_COOKIE_SECRET=your_16_byte_cookie_secret_here
# Cipher secret must be exactly 32 bytes (use: openssl rand -hex 32)
ORBITTO_KRATOS_CIPHER_SECRET=your_32_byte_cipher_secret_here

# ===================================================================
# Development Variables (Optional - have default values in compose.dev.yaml)
# ===================================================================
# Traefik (API Gateway)
# ORBITTO_TRAEFIK_LOG_LEVEL=INFO
# ORBITTO_TRAEFIK_EXPOSE_HTTP_PORT=80
# ORBITTO_TRAEFIK_EXPOSE_DASHBOARD_PORT=8080

# PostgreSQL Database
# ORBITTO_KRATOS_DB_EXPOSE_HTTP_PORT=5432

# Kratos (Identity & Access Management)
# ORBITTO_KRATOS_EXPOSE_PUBLIC_PORT=4433
# ORBITTO_KRATOS_EXPOSE_ADMIN_PORT=4434

# Profile Service
# ORBITTO_PROFILE_EXPOSE_PORT=8081

# Billing Service
# ORBITTO_BILLING_EXPOSE_PORT=8082

# BFF (GraphQL Gateway)
# ORBITTO_BFF_EXPOSE_PORT=3000

# ===================================================================
# Instructions:
# 1. Copy this file to .env: cp .env.example .env
# 2. Update the values above (especially secrets)
# 3. See docs/env.md for detailed documentation
# ===================================================================
